    "    (\"BRNN (BiLSTM)\", model_brnn, history_brnn),\n",
    "]:\n",
    "    acc      = history[\"test_acc\"][-1]\n",
    "    params   = count_parameters(model)\n",
    "    avg_time = sum(history[\"epoch_time\"]) / len(history[\"epoch_time\"])\n",
    "    print(f\"{name:<20} {acc:>10.4f} {params:>12,} {avg_time:>14.1f}s\")"
   ]
