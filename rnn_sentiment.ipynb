        "    \"It wasn't terrible but I wouldn't watch it again. The plot made no sense at times.\",\n",
        "]\n",
        "for review in test_reviews:\n",
        "    label, conf = predict_sentiment(review, model_brnn, vocab, device)\n",
        "    print(f\"[{label} ({conf:.2%})] — {review[:80]}...\")"
