    "def count_parameters(model):\n",
    "    return sum(p.numel() for p in model.parameters() if p.requires_grad)\n",
    "\n",
    "print(f\"{'Model':<20} {'Test Acc':>10} {'Parameters':>12} {'Avg Epoch Time':>16}\")\n",
